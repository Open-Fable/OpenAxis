# OpenAxis Environment Variables
# IMPORTANT: Real secrets go in ~/Library/Application Support/openaxis/secrets.enc (AES-256-GCM).
# This file documents the env vars that the process-manager injects at spawn time.

# Proxy token (generated per session by Electron main — never set manually)
# OPENAXIS_TOKEN=<auto-generated>

# Gemini OAuth — désactivé depuis le 18 juin 2026.
# Utiliser `opencode auth login` dans le terminal pour Gemini en direct.
# GEMINI_CLIENT_ID=
# GEMINI_CLIENT_SECRET=

# App ports (defaults — only override if you have conflicts)
# OPENWORK_APP_PORT=5173
# OPENCODE_PORT=4096
# OPENAXIS_PROXY_PORT=9999

# Node version manager (uncomment your tool)
# OPENAXIS_NODE_MANAGER=fnm
# OPENAXIS_NODE_MANAGER=volta
